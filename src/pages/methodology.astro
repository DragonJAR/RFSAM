---
import BaseLayout from '../layouts/BaseLayout.astro';
import { layers } from '../data/layers.js';
import { bsamRelation } from '../data/bsamRelation.js';
---
<BaseLayout title="Methodology">
  <div class="container">
    <h1 style="font-size:34px">Methodology</h1>

    <h2 class="mono" style="font-size:13px;letter-spacing:.16em;margin-top:32px;color:var(--mut2)">THE LAYER MODEL</h2>
    {layers.map((l) => (
      <div style="display:flex;gap:14px;padding:12px 0;border-bottom:1px solid var(--line)">
        <div class="mono" style={`width:46px;color:${l.color}`}>{l.id}</div>
        <div>
          <div style="font-family:var(--disp);font-weight:600">{l.name}</div>
          <div style="color:var(--mut);font-size:13px">{l.note}</div>
        </div>
      </div>
    ))}

    <h2 class="mono" style="font-size:13px;letter-spacing:.16em;margin-top:40px;color:var(--mut2)">WHY RFSAM &amp; WHAT IT BUILDS ON</h2>
    <p style="color:#CFD9E4;line-height:1.7;margin-top:10px">{bsamRelation.priorArt}</p>
    <p style="color:var(--mut);font-size:13.5px;line-height:1.7;margin-top:14px">
      Where an established methodology already owns a layer, RFSAM defers to it rather than duplicating —
      most notably <a style="color:var(--cyan)" href="/wayfinder/ble">Bluetooth, where it builds on Tarlogic's BSAM</a>.
      Each technology's reference methodology and the reasons to use it live on that technology's wayfinder.
    </p>
  </div>
</BaseLayout>
