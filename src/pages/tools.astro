---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = await getCollection('tools');
const hardware = tools.filter((t) => t.data.type === 'hardware').sort((a, b) => a.data.name.localeCompare(b.data.name));
const software = tools.filter((t) => t.data.type !== 'hardware').sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<BaseLayout title="Tools">
  <div class="container">
    <h1 style="font-size:34px">Tools</h1>
    <p style="color:var(--mut);margin-top:8px;max-width:64ch">
      Hardware first — open a device to see the software and projects that pair with it. Representative,
      not exhaustive; check current advisories. Repo links go to each project's source.
    </p>

    <h2 class="mono" style="font-size:13px;letter-spacing:.16em;color:var(--mut2);margin-top:32px">HARDWARE</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;margin-top:14px">
      {hardware.map((t) => <ToolCard tool={t.data} />)}
    </div>

    <h2 class="mono" style="font-size:13px;letter-spacing:.16em;color:var(--mut2);margin-top:40px">SOFTWARE &amp; PROJECTS</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;margin-top:14px">
      {software.map((t) => <ToolCard tool={t.data} />)}
    </div>
  </div>
</BaseLayout>
