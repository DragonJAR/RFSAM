---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { protocols } from '../../data/protocols.js';
import { layers } from '../../data/layers.js';
import { toolchains } from '../../data/toolchains.js';

export function getStaticPaths() {
  return protocols.map((p) => ({ params: { protocol: p.id.toLowerCase() }, props: { protocolId: p.id } }));
}

const { protocolId } = Astro.props;
const proto = protocols.find((p) => p.id === protocolId);
const tc = toolchains[protocolId] ?? { status: 'planned', reference: null, layers: {} };

const toolEntries = await getCollection('tools');
const toolBySlug = Object.fromEntries(toolEntries.map((t) => [t.id, t.data]));
const controls = await getCollection('controls');
const layerName = Object.fromEntries(layers.map((l) => [l.id, l.name]));

const STEP_DEFS = [
  { key: 'identify', name: 'Identify the device', layers: ['IG'] },
  { key: 'spectrum', name: 'See it in the spectrum', layers: ['SP'] },
  { key: 'capture', name: 'Capture the signal', layers: ['PHY', 'LL'] },
  { key: 'crypto', name: 'Break the crypto', layers: ['CR'] },
  { key: 'attack', name: 'Take over / attack', layers: ['AT'] },
  { key: 'app', name: 'Test the app layer', layers: ['AP'] },
];
const INTENTS = [
  { key: 'everything', label: 'Everything', steps: 'all' },
  { key: 'recon', label: 'Recon / sniff', steps: ['identify', 'spectrum', 'capture'] },
  { key: 'capture', label: 'Capture', steps: ['spectrum', 'capture'] },
  { key: 'decrypt', label: 'Decrypt', steps: ['capture', 'crypto'] },
  { key: 'attack', label: 'Take over', steps: ['capture', 'attack', 'app'] },
  { key: 'audit', label: 'Full audit', steps: 'all' },
];

const toolFull = (slug) => {
  const d = toolBySlug[slug];
  return d ? { slug, name: d.name, type: d.type, vendor: d.vendor, spec: d.spec ?? null, repo: d.repo ?? null, homepage: d.homepage ?? null, note: d.note } : null;
};

const steps = STEP_DEFS.map((sd) => {
  const notes = [];
  const entries = [];
  const ctrls = new Set();
  for (const lid of sd.layers) {
    const def = tc.layers?.[lid];
    if (def?.note) notes.push(def.note);
    for (const t of def?.tools ?? []) {
      const primary = toolFull(t.tool);
      if (!primary) continue;
      entries.push({ ...primary, role: t.role ?? null, why: t.why ?? null, caveat: t.caveat ?? null, needs: t.needs ?? null, deps: (t.deps ?? []).map(toolFull).filter(Boolean) });
    }
    controls.filter((c) => c.data.protocol === protocolId && c.data.layer === lid).forEach((c) => ctrls.add(c.data.id));
  }
  return { key: sd.key, name: sd.name, layers: sd.layers.map((l) => `${l} · ${layerName[l]}`), note: notes.join(' '), controls: [...ctrls], tools: entries };
});

const payload = JSON.stringify({
  protocol: { id: proto.id, name: proto.name, band: proto.band, status: tc.status, reference: tc.reference ?? null },
  steps, intents: INTENTS,
});
---
<BaseLayout title={`Wayfinder · ${proto.name}`}>
  <div id="wf">
    <header id="wf-top">
      <a href="/wayfinder" class="mono back">← all technologies</a>
      <div class="mono title">{proto.name} <span class="band">{proto.band}</span></div>
      <div id="wf-intents"><span class="lbl mono">SHOW</span></div>
    </header>
    <div id="wf-stage">
      <div id="wf-graph"></div>
      <aside id="wf-side"><div id="wf-side-body"></div></aside>
    </div>
  </div>

  <script type="application/json" id="wf-payload" set:html={payload}></script>

  <script>
    import ForceGraph from 'force-graph';

    const P = JSON.parse(document.getElementById('wf-payload').textContent);
    const esc = (s) => String(s ?? '').replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
    const linkA = (url, label) => url ? `<a href="${esc(url)}" target="_blank" rel="noopener">${label}</a>` : '';
    const slugify = (n) => n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    const TYPE_COLOR = { hardware: '#2FB8E0', software: '#3FD17C', project: '#9B8CFF' };

    // ---------- pinned, ordered layout (descent down the left, tools fanned right) ----------
    const STEP_GAP = 120, TOOL_X = 66, COL_W = 188, TOOL_VGAP = 30;
    const nodes = [], links = [];
    nodes.push({ id: 'tech', name: P.protocol.name, kind: 'tech', stepKey: '*', x: 0, y: 0, fx: 0, fy: 0, detail: { kind: 'tech' } });
    let prev = 'tech';
    P.steps.forEach((s, i) => {
      const sy = (i + 1) * STEP_GAP;
      const sid = 'step:' + s.key;
      nodes.push({ id: sid, name: `${i + 1}. ${s.name}`, kind: 'step', stepKey: s.key, x: 0, y: sy, fx: 0, fy: sy, detail: { kind: 'step', step: s } });
      links.push({ source: prev, target: sid, spine: true });
      prev = sid;
      const n = s.tools.length;
      const cols = n > 3 ? 2 : 1;
      const maxRows = Math.ceil(n / cols);
      s.tools.forEach((t, j) => {
        const col = cols === 2 ? j % 2 : 0;
        const row = cols === 2 ? Math.floor(j / 2) : j;
        const x = TOOL_X + col * COL_W;
        const y = sy + (row - (maxRows - 1) / 2) * TOOL_VGAP;
        const tid = sid + ':' + t.slug;
        nodes.push({ id: tid, name: t.name, kind: t.type, stepKey: s.key, x, y, fx: x, fy: y, detail: { kind: 'tool', tool: t } });
        links.push({ source: sid, target: tid });
      });
    });

    let intent = P.intents[0];
    const stepActive = (key) => key === '*' || intent.steps === 'all' || intent.steps.includes(key);
    const radius = (k) => k === 'tech' ? 8 : k === 'step' ? 5.5 : 4.5;
    const colorFor = (n) => n.kind === 'tech' ? '#FF7A1A' : n.kind === 'step' ? '#9B8CFF' : (TYPE_COLOR[n.kind] || '#8B9AAB');

    const el = document.getElementById('wf-graph');
    const graph = new ForceGraph(el)
      .backgroundColor('#0A1119')
      .cooldownTicks(0)
      .linkColor((l) => stepActive(targetStep(l)) ? (l.spine ? 'rgba(255,122,26,0.55)' : 'rgba(136,154,171,0.28)') : 'rgba(136,154,171,0.06)')
      .linkWidth((l) => l.spine ? 1.5 : 0.6)
      .linkDirectionalArrowLength((l) => l.spine ? 4 : 0)
      .linkDirectionalArrowRelPos(1)
      .nodeCanvasObject((node, ctx, scale) => {
        const active = stepActive(node.stepKey);
        ctx.globalAlpha = active ? 1 : 0.14;
        const r = radius(node.kind);
        ctx.beginPath(); ctx.arc(node.x, node.y, r, 0, 2 * Math.PI);
        ctx.fillStyle = colorFor(node); ctx.fill();
        const left = node.kind === 'step' || node.kind === 'tech';
        const fontSize = Math.max(4, (node.kind === 'step' ? 13 : node.kind === 'tech' ? 13 : 10.5) / scale);
        ctx.font = `${node.kind === 'tech' || node.kind === 'step' ? 600 : 400} ${fontSize}px Inter, system-ui, sans-serif`;
        ctx.textBaseline = 'middle';
        ctx.textAlign = left ? 'right' : 'left';
        const tx = left ? node.x - r - 5 : node.x + r + 5;
        ctx.lineWidth = 3 / scale; ctx.strokeStyle = 'rgba(10,17,25,0.92)';
        ctx.strokeText(node.name, tx, node.y);
        ctx.fillStyle = node.kind === 'tech' ? '#FF7A1A' : node.kind === 'step' ? '#E6EDF3' : '#C4D0DD';
        ctx.fillText(node.name, tx, node.y);
        ctx.globalAlpha = 1;
      })
      .nodePointerAreaPaint((node, color, ctx) => { ctx.beginPath(); ctx.arc(node.x, node.y, radius(node.kind) + 3, 0, 2 * Math.PI); ctx.fillStyle = color; ctx.fill(); })
      .onNodeClick((n) => showDetail(n))
      .onBackgroundClick(() => renderKit());

    function targetStep(l) { const t = typeof l.target === 'object' ? l.target : nodes.find((n) => n.id === l.target); return t ? t.stepKey : '*'; }
    graph.graphData({ nodes, links });
    graph.width(el.clientWidth).height(el.clientHeight);
    setTimeout(() => graph.zoomToFit(400, 70), 250);
    window.addEventListener('resize', () => graph.width(el.clientWidth).height(el.clientHeight));

    // ---------- intent chips ----------
    const chips = document.getElementById('wf-intents');
    P.intents.forEach((it) => {
      const b = document.createElement('button');
      b.textContent = it.label; b.dataset.k = it.key;
      if (it.key === intent.key) b.classList.add('on');
      b.onclick = () => { intent = it; chips.querySelectorAll('button').forEach((x) => x.classList.toggle('on', x.dataset.k === it.key)); renderKit(); };
      chips.appendChild(b);
    });

    // ---------- kit (the deliverable) ----------
    const side = document.getElementById('wf-side-body');
    const dedupe = (arr) => { const m = new Map(); arr.forEach((t) => m.set(t.slug, t)); return [...m.values()]; };
    function kitFor() {
      const hw = [], sw = [];
      P.steps.filter((s) => stepActive(s.key)).forEach((s) => s.tools.forEach((t) => {
        [t, ...(t.deps || [])].forEach((x) => (x.type === 'hardware' ? hw : sw).push(x));
      }));
      return { hw: dedupe(hw), sw: dedupe(sw) };
    }
    function kitRow(t) {
      const link = t.repo || t.homepage;
      return `<a class="kit-row" href="/tools/${esc(slugify(t.name))}"><span class="dot" style="background:${TYPE_COLOR[t.type] || '#8B9AAB'}"></span><span class="nm">${esc(t.name)}</span>${t.spec ? `<span class="sp">${esc(t.spec)}</span>` : ''}${link ? `<span class="rp">↗</span>` : ''}</a>`;
    }
    function renderKit() {
      const { hw, sw } = kitFor();
      const planned = P.protocol.status !== 'complete';
      side.innerHTML = `
        <div class="kicker">YOUR KIT · ${esc(intent.label)}</div>
        ${planned ? `<p class="muted">${esc(P.protocol.name)}'s toolchain is still being filled in. The descent and controls are here; the kit lands when the tools are curated.</p>` : ''}
        ${P.protocol.reference ? `<div class="ref">${linkA(P.protocol.reference.url, 'Reference: ' + esc(P.protocol.reference.name) + ' ↗')}</div>` : ''}
        <div class="kit-h">Hardware tools<span>${hw.length}</span></div>
        <div class="kit-list">${hw.map(kitRow).join('') || '<span class="muted">—</span>'}</div>
        <div class="kit-h">Software tools<span>${sw.length}</span></div>
        <div class="kit-list">${sw.map(kitRow).join('') || '<span class="muted">—</span>'}</div>
        <p class="hint mono">Click a step or tool in the graph for the reasons and the detail.</p>`;
    }

    function depBlock(t) {
      if (!t.deps?.length) return '';
      const label = t.type === 'hardware' ? 'RUNS' : 'RUNS ON';
      return `<div class="kicker">${label}</div><div class="deps">${t.deps.map((d) => `<a class="dep" href="/tools/${esc(d.slug)}"><span class="dot" style="background:${TYPE_COLOR[d.type] || '#8B9AAB'}"></span>${esc(d.name)}${d.spec ? `<span class="sp">${esc(d.spec)}</span>` : ''}</a>`).join('')}</div>`;
    }
    function showDetail(node) {
      const d = node.detail;
      if (d.kind === 'tech') return renderKit();
      let h = `<button class="back2" id="wf-back">← kit</button>`;
      if (d.kind === 'step') {
        const s = d.step;
        h += `<div class="kicker">${s.layers.map(esc).join(' · ')}</div><h2>${esc(s.name)}</h2>
          ${s.note ? `<p>${esc(s.note)}</p>` : ''}
          ${s.controls.length ? `<div class="kicker">CONTROLS</div><div class="chips">${s.controls.map((c) => `<a class="chip" href="/controls/${c.toLowerCase()}">${esc(c)}</a>`).join('')}</div>` : ''}`;
      } else if (d.kind === 'tool') {
        const t = d.tool, col = TYPE_COLOR[t.type] || '#8B9AAB';
        h += `<div class="badge" style="color:${col};border-color:${col}">${esc((t.type || '').toUpperCase())}</div>
          <h2>${esc(t.name)}</h2><div class="spec">${esc(t.vendor)}${t.spec ? ' · ' + esc(t.spec) : ''}</div>
          ${t.repo ? linkA(t.repo, 'GitHub repository ↗') : linkA(t.homepage, 'Project site ↗')}
          ${t.role ? `<div class="role">${esc(t.role)}</div>` : ''}
          ${t.why ? `<p>${esc(t.why)}</p>` : `<p class="muted">${esc(t.note)}</p>`}
          ${t.caveat ? `<p class="caveat">⚠ ${esc(t.caveat)}</p>` : ''}
          ${t.needs ? `<p class="needs"><b>NEEDS</b> ${esc(t.needs)}</p>` : ''}
          ${depBlock(t)}
          <a class="cta" href="/tools/${esc(t.slug)}">Full tool page →</a>`;
      }
      side.innerHTML = h;
      document.getElementById('wf-back').onclick = renderKit;
    }
    renderKit();
  </script>

  <style>
    #wf { height: calc(100vh - 53px); display: flex; flex-direction: column; }
    #wf-top { display: flex; align-items: center; gap: 16px; padding: 10px 16px; border-bottom: 1px solid var(--line); flex-wrap: wrap; }
    #wf-top .back { font-size: 11px; color: var(--mut); }
    #wf-top .title { font-size: 14px; color: var(--ink); }
    #wf-top .band { color: var(--mut2); font-size: 11px; }
    #wf-intents { margin-left: auto; display: flex; gap: 5px; align-items: center; flex-wrap: wrap; }
    #wf-intents .lbl { font-size: 9px; letter-spacing: .16em; color: var(--mut2); margin-right: 4px; }
    #wf-intents button { font-family: var(--mono); font-size: 11px; color: var(--mut); background: rgba(255,255,255,.03); border: 1px solid var(--line); border-radius: 999px; padding: 4px 13px; cursor: pointer; transition: all .12s; }
    #wf-intents button:hover { color: var(--ink); border-color: var(--line2); background: rgba(255,255,255,.07); }
    #wf-intents button.on { color: #0A1119; background: var(--orange); border-color: var(--orange); font-weight: 600; }
    #wf-stage { flex: 1; display: flex; min-height: 0; }
    #wf-graph { flex: 1; min-width: 0; }
    #wf-side { width: 350px; flex: 0 0 350px; border-left: 1px solid var(--line); background: var(--bg2); overflow-y: auto; padding: 20px 20px 48px; }
    #wf-side .kicker { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; color: var(--mut2); margin: 18px 0 6px; }
    #wf-side h2 { font-family: var(--disp); font-size: 21px; margin: 8px 0 4px; line-height: 1.15; }
    #wf-side .spec { font-family: var(--mono); font-size: 12px; color: var(--mut2); margin-bottom: 10px; }
    #wf-side p { color: #CFD9E4; font-size: 13.5px; line-height: 1.65; margin: 10px 0; }
    #wf-side .muted { color: var(--mut); }
    #wf-side .caveat { color: #E7DCC2; }
    #wf-side .needs { font-family: var(--mono); font-size: 12px; color: var(--cyan); } #wf-side .needs b { color: var(--mut2); letter-spacing: .1em; margin-right: 4px; }
    #wf-side .role { font-family: var(--mono); font-size: 12px; color: var(--orange); margin-top: 12px; letter-spacing: .03em; }
    #wf-side a { color: var(--cyan); }
    #wf-side .ref { font-family: var(--mono); font-size: 11px; margin: 10px 0; }
    #wf-side .kit-h { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--disp); font-weight: 600; font-size: 14px; margin: 22px 0 8px; border-bottom: 1px solid var(--line); padding-bottom: 6px; }
    #wf-side .kit-h span { font-family: var(--mono); font-size: 12px; color: var(--mut2); }
    #wf-side .kit-row { display: flex; align-items: center; gap: 9px; padding: 7px 0; border-bottom: 1px solid rgba(34,52,74,.45); }
    #wf-side .kit-row .nm { color: var(--ink); font-size: 13.5px; }
    #wf-side .kit-row .sp { font-family: var(--mono); font-size: 9.5px; color: var(--mut2); margin-left: auto; text-align: right; }
    #wf-side .kit-row .rp { color: var(--amber); margin-left: 8px; }
    #wf-side .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    #wf-side .deps { display: flex; flex-direction: column; gap: 4px; }
    #wf-side .dep { display: flex; align-items: center; gap: 8px; padding: 5px 0; font-size: 13px; color: var(--ink); }
    #wf-side .dep .sp { font-family: var(--mono); font-size: 9.5px; color: var(--mut2); margin-left: auto; }
    #wf-side .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    #wf-side .chip { font-family: var(--mono); font-size: 11px; border: 1px solid var(--line2); border-radius: 4px; padding: 3px 9px; color: var(--cyan); }
    #wf-side .badge { display: inline-block; font-family: var(--mono); font-size: 10px; border: 1px solid; border-radius: 3px; padding: 2px 8px; }
    #wf-side .cta, #wf-side .back2 { display: inline-block; margin-top: 18px; font-family: var(--mono); font-size: 12px; color: var(--orange); background: none; border: 0; cursor: pointer; padding: 0; }
    #wf-side .hint { font-size: 10px; color: var(--mut2); margin-top: 22px; }
    :global(body:has(#wf)) footer { display: none; }
    @media (max-width: 760px) { #wf-side { display: none; } }
  </style>
</BaseLayout>
